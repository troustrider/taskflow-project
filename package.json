{
  "name": "ffe-corner-estudios",
  "version": "1.0.0",
  "description": "TaskFlow — app ligera de gestión de tareas con drag-and-drop, temas, geolocalización y sintaxis rápida de entrada",
  "main": "app.js",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./input.css -o ./css/output.css --watch",
    "build:css": "npx @tailwindcss/cli -i ./input.css -o ./css/output.css --minify",
    "build": "npm run build:css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/troustrider/taskflow-project.git"
  },
  "keywords": ["task-manager", "vanilla-js", "tailwindcss", "express", "rest-api", "swagger"],
  "author": "troustrider",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/troustrider/taskflow-project/issues"
  },
  "homepage": "https://github.com/troustrider/taskflow-project#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
